# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Test / tooling caches
.cache/
.turbo/
.vite/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS noise
.DS_Store
Thumbs.db

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Local development scratch — never commit
scratch/
tmp/
.tmp/

# Defensive: block common credential leak patterns
**/*service-account*.json
**/*serviceaccount*.json
**/*adminsdk*.json
**/*firebase*credentials*
**/*.pem
**/*.key
